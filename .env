# Local development environment
PORT=3000
NODE_ENV=development

# Square — leave blank in dev, signature check is skipped automatically
SQUARE_WEBHOOK_SIGNATURE_KEY=
SQUARE_ENVIRONMENT=sandbox

# Admin key for local testing
ADMIN_API_KEY=localadmin123

# Database
DB_PATH=./data/dozer.db

# Pricing (AUD per minute) — placeholder until confirmed
PRICE_PER_MINUTE_AUD=0.30

# Battery
LOW_BATTERY_THRESHOLD_PERCENT=15
BATTERY_MAX_VOLTAGE=12.6
BATTERY_MIN_VOLTAGE=10.5

# Device timeout
DEVICE_TIMEOUT_SECONDS=30
