# Server
PORT=3000
NODE_ENV=development

# Square Payments
# Get this from: Square Developer Dashboard -> Your App -> Webhooks -> Signature Key
SQUARE_WEBHOOK_SIGNATURE_KEY=your_square_webhook_signature_key_here
# Set to 'production' when going live
SQUARE_ENVIRONMENT=sandbox

# Admin API
ADMIN_API_KEY=change_this_to_a_strong_random_key

# Database
DB_PATH=./data/dozer.db

# Business config (AUD per minute — update when pricing is confirmed)
PRICE_PER_MINUTE_AUD=0.20

# Battery thresholds
LOW_BATTERY_THRESHOLD_PERCENT=15
BATTERY_MAX_VOLTAGE=12.6
BATTERY_MIN_VOLTAGE=10.5

# Device heartbeat timeout — mark offline after this many seconds with no heartbeat
DEVICE_TIMEOUT_SECONDS=30
